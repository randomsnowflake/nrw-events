# Copy this file to `.env` and fill in the keys/settings you want.
# The tool runs without API keys; deterministic public sources do the heavy lifting.
# Real environment variables take precedence over values from this file.

# Exa neural web search (https://exa.ai) — enables the broad-web event fallback.
EXA_API_KEY=

# xAI Grok (https://x.ai) — enables the optional agentic search sweep.
# Also requires NRW_EVENTS_ENABLE_GROK=1 at runtime.
XAI_API_KEY=
NRW_EVENTS_ENABLE_GROK=0

# Output paths default to $XDG_STATE_HOME/nrw-events (or
# ~/.local/state/nrw-events when XDG_STATE_HOME is unset).
# NRW_EVENTS_JSON_OUT=~/.local/state/nrw-events/nrw-events-latest.json
# NRW_EVENTS_META_JSON_OUT=~/.local/state/nrw-events/nrw-events-latest-meta.json
# Optional durable last-published metadata used to retain unexpired events when
# an individual source is temporarily unavailable. Defaults to META_JSON_OUT.
NRW_EVENTS_PREVIOUS_META_JSON=

# Report filtering. 0/unset means show every deduplicated relevant event.
# NRW_EVENTS_DAYS_AHEAD=3
# NRW_EVENTS_MAX_PER_SECTION=0
# NRW_EVENTS_SCORE_FLOOR=0.4
# NRW_EVENTS_DESCRIPTION_MAX_CHARS=700

# Search fallback size. Exa returns roughly five results per query.
# NRW_EVENTS_EXA_QUERIES=10

# HTTP behaviour for public event sources.
# NRW_EVENTS_USER_AGENT=
# NRW_EVENTS_HTTP_RETRY_ATTEMPTS=5
# NRW_EVENTS_HTTP_RETRY_BASE_SECONDS=1.0
# NRW_EVENTS_HTTP_RETRY_MAX_DELAY_SECONDS=60.0
# NRW_EVENTS_HTTP_MAX_RESPONSE_BYTES=5000000
# NRW_EVENTS_SOURCE_BASELINE_MIN_COUNT=10
# NRW_EVENTS_BONN_DE_DELAY_SECONDS=2.0
# NRW_EVENTS_BONN_CALENDAR_MAX_PAGES=30
# Bright Data Web Unlocker credentials. The Monday-only vomFASS refresh always
# uses this proxy; no direct vomFASS request is attempted.
BRIGHT_DATA_API_KEY=
BRIGHT_DATA_ZONE=
# Event detail pages are cached per source. This protects municipal and venue
# servers when the website is rebuilt several times in a short period while
# still refreshing generic detail pages daily by default.
# NRW_EVENTS_CACHE_DIR=~/.cache/nrw-events
# NRW_EVENTS_DETAIL_CACHE_TTL_HOURS=24
# NRW_EVENTS_BONN_DETAIL_DESCRIPTION_MAX_CHARS=500

# Optional durable logs for unattended runs. JSON logs are one object per line.
# NRW_EVENTS_LOG_LEVEL=INFO
# NRW_EVENTS_LOG_FILE=/var/log/nrw-events/import.log
# NRW_EVENTS_JSON_LOG_FILE=/var/log/nrw-events/import.jsonl

# Optional explicit env-file path for wrappers/callers.
# NRW_EVENTS_ENV_FILE=/absolute/path/to/.env
