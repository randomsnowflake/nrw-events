# Copy this file to `.env` and fill in the keys/settings you want.
# The tool runs without API keys; deterministic public sources do the heavy lifting.
# Real environment variables take precedence over values from this file.

# Exa neural web search (https://exa.ai) — enables the broad-web event fallback.
EXA_API_KEY=

# xAI Grok (https://x.ai) — enables the optional agentic search sweep.
# Also requires NRW_EVENTS_ENABLE_GROK=1 at runtime.
XAI_API_KEY=
NRW_EVENTS_ENABLE_GROK=0

# Output paths. Defaults are /tmp/nrw-events-latest.json and
# /tmp/nrw-events-latest-meta.json when unset.
# NRW_EVENTS_JSON_OUT=/tmp/nrw-events-latest.json
# NRW_EVENTS_META_JSON_OUT=/tmp/nrw-events-latest-meta.json

# Report filtering. 0/unset means show every deduplicated relevant event.
# NRW_EVENTS_DAYS_AHEAD=3
# NRW_EVENTS_MAX_PER_SECTION=0
# NRW_EVENTS_SCORE_FLOOR=0.4

# Search fallback size. Exa returns roughly five results per query.
# NRW_EVENTS_EXA_QUERIES=10

# HTTP behaviour for public event sources.
# NRW_EVENTS_USER_AGENT=
# NRW_EVENTS_HTTP_RETRY_ATTEMPTS=5
# NRW_EVENTS_HTTP_RETRY_BASE_SECONDS=1.0
# NRW_EVENTS_BONN_DE_DELAY_SECONDS=2.0

# Optional durable logs for unattended runs. JSON logs are one object per line.
# NRW_EVENTS_LOG_LEVEL=INFO
# NRW_EVENTS_LOG_FILE=/var/log/nrw-events/import.log
# NRW_EVENTS_JSON_LOG_FILE=/var/log/nrw-events/import.jsonl

# Optional explicit env-file path for wrappers/callers.
# NRW_EVENTS_ENV_FILE=/absolute/path/to/.env
