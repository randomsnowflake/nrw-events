# Copy this file to `.env` and fill in the keys you have.
# Both keys are OPTIONAL — the deterministic scrapers run without them.
# Real environment variables take precedence over this file.

# Exa neural web search (https://exa.ai) — enables the broad-web event fallback.
EXA_API_KEY=

# xAI Grok (https://x.ai) — enables the optional agentic search sweep.
# Also requires NRW_EVENTS_ENABLE_GROK=1 at runtime.
XAI_API_KEY=
